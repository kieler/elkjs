{
  "name": "elkjs",
  "version": "0.12.0",
  "author": {
    "name": "Ulf Rüegg",
    "email": "uruurumail@gmail.com"
  },
  "description": "Automatic graph layout based on Sugiyama's algorithm. Specialized for data flow diagrams and ports.",
  "main": "lib/main",
  "types": "lib/main",
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kieler/elkjs.git"
  },
  "keywords": [
    "graph",
    "layout",
    "layered",
    "ports",
    "dataflow"
  ],
  "license": "EPL-2.0 OR GPL-3.0-or-later",
  "scripts": {
    "test": "mocha test/mocha",
    "gradle": "./gradlew lib",
    "stage": "mkdirp build/js && cp src/js/*.js build/js/",
    "bundle": "mkdirp lib && rollup -c",
    "cp": "cp build/js/elk-worker*.js lib/ && cp build/js/main-node.js lib/main.js && cp typings/*.d.ts lib/",
    "js": "npm run stage && npm run bundle && npm run cp",
    "build": "npm run gradle && npm run js",
    "clean": "./gradlew clean && rm -rf lib build/js",
    "setDevVersion": "npm version --no-git-tag-version \"$(node -p \"require('./package.json').version\")-dev-$(date '+%Y%m%d')\""
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "chai": "^4.0.2",
    "chai-as-promised": "^7.1.1",
    "mkdirp": "^3.0.1",
    "mocha": "^11.0.0",
    "rollup": "^4.62.2",
    "web-worker": "1.4.1"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
